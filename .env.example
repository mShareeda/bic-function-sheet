# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bic_function_sheet?schema=public"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-32-byte-random-string"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- M365 / Entra ID SSO (scaffolded but disabled by default) ---
AUTH_M365_ENABLED="false"
AUTH_MICROSOFT_ENTRA_ID="your-client-id"
AUTH_MICROSOFT_ENTRA_SECRET="your-client-secret"
AUTH_MICROSOFT_ENTRA_TENANT_ID="your-tenant-id"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxx"
EMAIL_FROM="BIC Function Sheet <noreply@bic.example>"
# In dev, set to "console" to log emails instead of sending
MAIL_DRIVER="console"

# --- Storage ---
# "local" for dev, "azure" for prod
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"
AZURE_STORAGE_ACCOUNT=""
AZURE_STORAGE_KEY=""
AZURE_STORAGE_CONTAINER="attachments"

# --- App ---
APP_URL="http://localhost:3000"
APP_TIMEZONE="Asia/Bahrain"
MAX_ATTACHMENT_BYTES="26214400"

# --- Bootstrap ---
# Used by prisma/seed.ts to create the first admin
BOOTSTRAP_ADMIN_EMAIL="admin@bic.local"
BOOTSTRAP_ADMIN_NAME="BIC Admin"
