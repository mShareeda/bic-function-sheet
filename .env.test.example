# Copy this file to .env.test and fill in the values before running E2E tests.

# Admin user credentials (must exist in the DB — created by prisma/seed.ts).
# The password is printed once to the console on first seed.
E2E_ADMIN_EMAIL=admin@bic.local
E2E_ADMIN_PASSWORD=replace-with-your-password

# Override the app URL if the dev server runs on a different port.
# BASE_URL=http://localhost:3000

# Set to 1 in CI if you start the server yourself before running tests.
# SKIP_WEBSERVER=1
